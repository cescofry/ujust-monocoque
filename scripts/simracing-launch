#!/usr/bin/env bash
# Unified sim racing launcher — starts telemetry stack and runs the game.
# Usage: simracing-launch [bridge_exe|none] %command%
#   bridge_exe: path to simshmbridge .exe, or "none" for games with native shm/UDP
set -euo pipefail

BRIDGE="${1:-none}"; shift

# Kill Boxflat if running — it holds the serial port and blocks monocoque
if pgrep -f "boxflat" >/dev/null 2>&1; then
    echo "[simracing] Stopping Boxflat (serial port conflict)..."
    pkill -f "boxflat" 2>/dev/null || true
    sleep 1
fi

cleanup() {
    echo "[simracing] Game exited, stopping telemetry stack..."
    [ -n "${SIMD_PID:-}" ] && kill "$SIMD_PID" 2>/dev/null || true
    [ -n "${MONO_PID:-}" ] && kill "$MONO_PID" 2>/dev/null || true
}
trap cleanup EXIT

# Start simd if not already running
SIMD_PID=""
if ! pgrep -f "simd" >/dev/null 2>&1; then
    echo "[simracing] Starting simd..."
    distrobox enter simracing -- simd &
    SIMD_PID=$!
    sleep 2
else
    echo "[simracing] simd already running."
fi

# Start monocoque if not already running
MONO_PID=""
if ! pgrep -f "monocoque.*play" >/dev/null 2>&1; then
    echo "[simracing] Starting monocoque..."
    distrobox enter simracing -- monocoque play &
    MONO_PID=$!
else
    echo "[simracing] monocoque already running."
fi

# Launch the game (with or without bridge)
if [ "$BRIDGE" != "none" ] && [ -f "$BRIDGE" ]; then
    # Find the game .exe in the args (last arg ending in .exe)
    ARGS=("$@")
    GAME_EXE_IDX=""
    for i in "${!ARGS[@]}"; do
        case "${ARGS[$i]}" in
            *.exe) GAME_EXE_IDX=$i ;;
        esac
    done

    if [ -n "$GAME_EXE_IDX" ]; then
        GAME_EXE="${ARGS[$GAME_EXE_IDX]}"
        GAME_DIR=$(dirname "$GAME_EXE")
        GAME_NAME=$(basename "$GAME_EXE")
        BRIDGE_NAME=$(basename "$BRIDGE")

        echo "[simracing] Injecting bridge ($BRIDGE_NAME) into game session"

        # Copy bridge exe into game directory so Wine can access it
        cp -f "$BRIDGE" "$GAME_DIR/$BRIDGE_NAME"

        # Create a .vbs wrapper that launches bridge + game in same Wine session
        # Uses wscript.exe (GUI host) instead of cmd.exe to avoid a console window
        cat > "$GAME_DIR/simracing_wrapper.vbs" << VBSEOF
Set WshShell = CreateObject("WScript.Shell")
scriptDir = Replace(WScript.ScriptFullName, WScript.ScriptName, "")
' Launch bridge hidden (0 = hidden window)
WshShell.Run Chr(34) & scriptDir & "${BRIDGE_NAME}" & Chr(34), 0, False
' Launch game and wait for it to exit
WshShell.Run Chr(34) & scriptDir & "${GAME_NAME}" & Chr(34), 1, True
' Kill bridge after game exits
WshShell.Run "taskkill /f /im ${BRIDGE_NAME}", 0, True
VBSEOF

        # Replace game exe with our wrapper in the launch args
        ARGS[$GAME_EXE_IDX]="$GAME_DIR/simracing_wrapper.vbs"
        echo "[simracing] Launching with bridge wrapper..."
        "${ARGS[@]}"
    else
        echo "[simracing] WARNING: Could not find .exe in launch command"
        "$@"
    fi
else
    "$@"
fi
